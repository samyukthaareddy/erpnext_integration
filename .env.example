# ERPNext Configuration
ERPNEXT_BASE_URL=http://your-erpnext-instance.local
ERPNEXT_API_KEY=your_api_key_here
ERPNEXT_API_SECRET=your_api_secret_here

# Application Configuration
FLASK_ENV=development
FLASK_DEBUG=True
LOG_LEVEL=DEBUG

# Assignment Configuration
DEFAULT_ASSIGNMENT_STRATEGY=round_robin

# Internal API Key (leave empty to disable enforcement in dev)
INTERNAL_API_KEY=

# Optional: Redis Configuration (for future implementation)
# REDIS_URL=redis://localhost:6379/0
